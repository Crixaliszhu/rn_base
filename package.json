{
  "name": "hybrid-demo-rn-module",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "start": "node scripts/start.js",
    "metro": "react-native start",
    "bundle:android": "react-native bundle --platform android --dev false --entry-file index.js --bundle-output ./output/index.android.bundle --assets-dest ./output/res",
    "bundle:android:dev": "react-native bundle --platform android --dev true --entry-file index.js --bundle-output ./output/index.android.bundle --assets-dest ./output/res"
  },
  "dependencies": {
    "react": "18.2.0",
    "react-native": "0.72.5"
  },
  "devDependencies": {
    "@babel/core": "^7.22.1",
    "@babel/runtime": "^7.22.1",
    "@types/react": "^18.2.0",
    "babel-plugin-module-resolver": "^5.0.3",
    "metro-react-native-babel-preset": "0.76.8",
    "typescript": "5.0.4"
  }
}
